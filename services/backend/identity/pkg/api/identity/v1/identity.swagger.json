{
  "swagger": "2.0",
  "info": {
    "title": "identity/v1/identity.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "IdentityService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/.well-known/jwks.json": {
      "get": {
        "summary": "GetJWKS publishes the current + previous public keys as a JWK Set so every\nverifier can validate JWTs locally and tolerate key rotation.",
        "operationId": "IdentityService_GetJWKS",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetJWKSResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "tags": [
          "IdentityService"
        ]
      }
    },
    "/v1/auth/me": {
      "get": {
        "summary": "GetMe returns the current user's profile. The subject is derived from the\nBearer access token in request metadata, never from the request body.",
        "operationId": "IdentityService_GetMe",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetMeResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "tags": [
          "IdentityService"
        ]
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "summary": "RefreshToken performs a rotating refresh: the presented refresh token is\ninvalidated and a new pair is issued. Reuse of an old token revokes the\nsession (reuse detection).",
        "operationId": "IdentityService_RefreshToken",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1RefreshTokenResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1RefreshTokenRequest"
            }
          }
        ],
        "tags": [
          "IdentityService"
        ]
      }
    },
    "/v1/auth/revoke": {
      "post": {
        "summary": "Revoke kills a session (sign-out / security event) by refresh token or\nsession id. Deleting the session invalidates its refresh token instantly.",
        "operationId": "IdentityService_Revoke",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1RevokeResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1RevokeRequest"
            }
          }
        ],
        "tags": [
          "IdentityService"
        ]
      }
    },
    "/v1/auth/signin": {
      "post": {
        "summary": "SignIn verifies an Apple/Google ID token or an email+password and returns a\nfresh access/refresh token pair. First social login creates the user.",
        "operationId": "IdentityService_SignIn",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1SignInResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1SignInRequest"
            }
          }
        ],
        "tags": [
          "IdentityService"
        ]
      }
    },
    "/v1/auth/validate": {
      "post": {
        "summary": "ValidateToken verifies an access token locally (crypto + claims). Used by\nthe gateway only when needed; hot-path validation is local via JWKS.",
        "operationId": "IdentityService_ValidateToken",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ValidateTokenResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1ValidateTokenRequest"
            }
          }
        ],
        "tags": [
          "IdentityService"
        ]
      }
    }
  },
  "definitions": {
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "protobufNullValue": {
      "type": "string",
      "enum": [
        "NULL_VALUE"
      ],
      "default": "NULL_VALUE",
      "description": "Represents a JSON `null`.\n\n`NullValue` is a sentinel, using an enum with only one value to represent\nthe null value for the `Value` type union.\n\nA field of type `NullValue` with any value other than `0` is considered\ninvalid. Most ProtoJSON serializers will emit a `Value` with a `null_value`\nset as a JSON `null` regardless of the integer value, and so will round trip\nto a `0` value.\n\n - NULL_VALUE: Null value."
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1GetJWKSResponse": {
      "type": "object",
      "properties": {
        "keys": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1JWK"
          }
        }
      }
    },
    "v1GetMeResponse": {
      "type": "object",
      "properties": {
        "user": {
          "$ref": "#/definitions/v1User"
        }
      }
    },
    "v1JWK": {
      "type": "object",
      "properties": {
        "kty": {
          "type": "string",
          "title": "\"OKP\""
        },
        "crv": {
          "type": "string",
          "title": "\"Ed25519\""
        },
        "x": {
          "type": "string",
          "title": "base64url public key"
        },
        "kid": {
          "type": "string",
          "title": "key id"
        },
        "use": {
          "type": "string",
          "title": "\"sig\""
        },
        "alg": {
          "type": "string",
          "title": "\"EdDSA\""
        }
      },
      "description": "JWK is a single public key in JWK form (RFC 7517 / RFC 8037 for OKP)."
    },
    "v1Provider": {
      "type": "string",
      "enum": [
        "PROVIDER_UNSPECIFIED",
        "PROVIDER_APPLE",
        "PROVIDER_GOOGLE",
        "PROVIDER_EMAIL"
      ],
      "default": "PROVIDER_UNSPECIFIED",
      "description": "Provider identifies the sign-in method."
    },
    "v1RefreshTokenRequest": {
      "type": "object",
      "properties": {
        "refreshToken": {
          "type": "string"
        }
      }
    },
    "v1RefreshTokenResponse": {
      "type": "object",
      "properties": {
        "accessToken": {
          "type": "string"
        },
        "refreshToken": {
          "type": "string"
        },
        "expiresIn": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "v1RevokeRequest": {
      "type": "object",
      "properties": {
        "refreshToken": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        }
      }
    },
    "v1RevokeResponse": {
      "type": "object"
    },
    "v1SignInRequest": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/v1Provider"
        },
        "idToken": {
          "type": "string",
          "description": "For social sign-in: the provider-issued ID token (JWT)."
        },
        "email": {
          "type": "string",
          "title": "For email/password sign-in:"
        },
        "password": {
          "type": "string"
        },
        "displayName": {
          "type": "string",
          "title": "optional, used when first creating an account"
        },
        "device": {
          "type": "string",
          "description": "Optional device label recorded on the session (e.g. \"iPhone 15\")."
        }
      }
    },
    "v1SignInResponse": {
      "type": "object",
      "properties": {
        "accessToken": {
          "type": "string"
        },
        "refreshToken": {
          "type": "string"
        },
        "expiresIn": {
          "type": "string",
          "format": "int64",
          "title": "access-token lifetime, seconds"
        },
        "user": {
          "$ref": "#/definitions/v1User"
        }
      }
    },
    "v1User": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "title": "uuid"
        },
        "email": {
          "type": "string",
          "title": "may be empty for social-only accounts"
        },
        "displayName": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "title": "active | disabled"
        },
        "createdAt": {
          "type": "string",
          "title": "RFC 3339"
        }
      },
      "description": "User is the basic public profile Identity owns."
    },
    "v1ValidateTokenRequest": {
      "type": "object",
      "properties": {
        "accessToken": {
          "type": "string"
        }
      }
    },
    "v1ValidateTokenResponse": {
      "type": "object",
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "subject": {
          "type": "string",
          "title": "user id when valid"
        },
        "claims": {
          "type": "object",
          "title": "decoded claims when valid"
        }
      }
    }
  }
}
