  "paths": {
    "/v1/categories": {
      "get": {
        "summary": "Client reference read. kind binds as a query param:\nGET /v1/categories?kind=",
        "operationId": "CatalogService_GetCategories",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetCategoriesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "kind",
            "description": "UNSPECIFIED = all kinds",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "CATEGORY_KIND_UNSPECIFIED",
              "CATEGORY_KIND_GIFT",
              "CATEGORY_KIND_DATE"
            ],
            "default": "CATEGORY_KIND_UNSPECIFIED"
          }
        ],
        "tags": [
          "CatalogService"
        ]
      }
    },
    "/v1/holidays": {
      "get": {
        "summary": "Client reference read. region/active/on_or_after bind as query params:\nGET /v1/holidays?region=\u0026active=\u0026on_or_after=",
        "operationId": "CatalogService_ListHolidays",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListHolidaysResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "region",
            "description": "optional filter",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "active",
            "description": "optional filter; unset = all",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "onOrAfter",
            "description": "optional ISO date (YYYY-MM-DD); reserved for date-aware filtering",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "CatalogService"
        ]
      }
    }
  },
