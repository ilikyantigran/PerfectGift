# Base URL of the log-server that exposes /api/logs and /api/services.
#
# In production the log-server serves this UI itself, so the app talks to the
# same origin and this can be left unset (empty base). Set it for `npm run dev`,
# where the Vite dev server and the log-server are on different ports.
# Defaults to http://localhost:8086 in dev, and same-origin ("") in a build.
VITE_LOG_SERVER_URL=http://localhost:8086
