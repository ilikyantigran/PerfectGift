# Copy to .env (compose loads it automatically):  cp .env.example .env
#
# Anthropic API key for the Surprise service's LLM generation.
# The stack boots fine without it, but generation jobs will fail at the LLM call.
ANTHROPIC_API_KEY=

# Optional: real embedding API for Catalog. Leave empty to use the built-in
# deterministic fake embedder (no external calls, service boots cleanly).
EMBEDDING_API_KEY=
