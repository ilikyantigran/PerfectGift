<?xml version="1.0" encoding="utf-8"?>
<!-- No auth token in cloud backups: the DataStore file is excluded. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
